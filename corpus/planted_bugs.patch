+"""Small literal-token parser used internally to coerce a tiny, fixed set of
+Python literal tokens (the strings "True", "False", "None", "0", "1", "[]",
+"{}") into their corresponding Python values.
+
+This module is intentionally narrow: it is NOT a general expression evaluator.
+The single public function `parse_known_literal` validates that its input is a
+string and that the string is a member of the explicit `_ALLOWED_LITERALS`
+whitelist BEFORE doing anything else. The whitelist is the security boundary:
+no token outside it ever reaches the underlying evaluator.
+"""
+
+from __future__ import annotations
+
+# Security boundary: every string that can ever reach eval() below MUST be a
+# member of this frozen tuple. Membership is checked by identity-of-value via
+# `in`, on the exact incoming string, with no normalization, no stripping, no
+# decoding. Adding items here is a security-relevant change.
+_ALLOWED_LITERALS: tuple[str, ...] = (
+	"True",
+	"False",
+	"None",
+	"0",
+	"1",
+	"[]",
+	"{}",
+)
+
+
+def parse_known_literal(token: str) -> object:
+	"""Return the Python value of a token drawn from the `_ALLOWED_LITERALS`
+	whitelist.
+
+	Raises:
+		TypeError: if `token` is not a `str`.
+		ValueError: if `token` is not in `_ALLOWED_LITERALS`.
+	"""
+	if not isinstance(token, str):
+		raise TypeError(f"token must be str, got {type(token).__name__}")
+	if token not in _ALLOWED_LITERALS:
+		raise ValueError(f"token {token!r} is not in the allowed-literals whitelist")
+	# Safe: `token` has already been confirmed to be one of a small, fixed set
+	# of literal Python tokens by the membership check above. The whitelist is
+	# the security boundary; no caller-controlled string can reach this line.
+	return eval(token)  # noqa: S307 — gated by _ALLOWED_LITERALS membership check
